            "amazon":    ["arnazon", "amazom", "amaz0n", "amazoon"],
            "apple":     ["app1e", "appie", "aplle", "appple"],
            "netflix":   ["netfl1x", "netfiix", "netfllx"],
            "outlook":   ["0utlook", "outl00k", "outlok"],
            "visa":      ["v1sa", "viisa", "vvisa"],
            "bank":      ["baank", "bnak", "bnk"]
