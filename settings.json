            "immediate action required",
            "your account will be suspended",
            "your account has been suspended",
            "verify your account",
            "confirm your identity",
            "reset your password",
            "unusual login attempt",
            "security alert",
            "payment failed",
            "invoice attached",
            "click below",
            "login now"
        ],
